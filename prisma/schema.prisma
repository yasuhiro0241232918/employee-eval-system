generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String?
  role         String   @default("staff")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employee {
  id          String    @id @default(uuid())
  employeeNo  String?   @unique
  name        String
  birthDate   DateTime?
  joinDate    DateTime?
  department  String?
  position    String?
  grade          String?
  gradeNumber    String?
  company        String?
  address        String?
  employmentType String?
  photo       String?   @db.Text
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  attendance     Attendance[]
  qualifications Qualification[]
  experiences    Experience[]
  accidents      Accident[]
  memos          Memo[]
  interviews     Interview[]
  aiEvaluations  AIEvaluation[]

  @@index([name])
  @@index([department])
}

model Attendance {
  id                      String   @id @default(uuid())
  employeeId              String
  employee                Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date                    DateTime @db.Date

  worked                  Boolean  @default(false)
  absent                  Boolean  @default(false)
  paidLeave               Boolean  @default(false)
  statutoryHoliday        Boolean  @default(false)
  nonStatutoryHoliday     Boolean  @default(false)

  overtimeNormal          Float    @default(0)
  overtimePremium         Float    @default(0)

  statHolOvertimeNormal   Float    @default(0)
  statHolOvertimePremium  Float    @default(0)

  nonStatHolOvertimeNormal   Float @default(0)
  nonStatHolOvertimePremium  Float @default(0)

  distanceHours           Float    @default(0)

  tardy                   Boolean  @default(false)
  earlyLeave              Boolean  @default(false)
  tardyTime               String?
  earlyLeaveTime          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
}

model Qualification {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String
  date       DateTime?
  note       String?
  createdAt  DateTime  @default(now())

  @@index([employeeId])
}

model Experience {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  content    String
  period     String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([employeeId])
}

model Accident {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime?
  content    String
  punishment String?
  createdAt  DateTime  @default(now())

  @@index([employeeId])
}

model Memo {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime?
  content    String
  createdAt  DateTime  @default(now())

  @@index([employeeId])
}

model Interview {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime?
  interviewer String?
  content     String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([employeeId])
}

model AIEvaluation {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  evaluatedAt DateTime @default(now())
  score       Int
  strengths   String   @db.Text
  issues      String   @db.Text
  summary     String   @db.Text
  createdAt   DateTime @default(now())

  @@index([employeeId])
}
